# LeaseAlign AI — Environment Variables
# Copy this file to .env and fill in your actual credentials.

# Server running port
PORT=8000

# Your AI provider API developer keys
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# Supabase database configuration parameters
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Stripe payment & webhook keys
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# Twilio Credentials for Phone Verification
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_VERIFY_SERVICE_SID=

# Cron endpoints secure secret token
CRON_SECRET=

# Internal worker token for async auditing authentication
INTERNAL_WORKER_SECRET=

# Optional Sentry logging configuration
SENTRY_DSN=
