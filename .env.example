# LeaseAlign AI — Environment Variables
# Copy this file to .env and fill in your actual credentials.

# Server running port
PORT=8000

# Your AI provider API developer keys
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# Supabase database configuration parameters
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Stripe payment & webhook keys
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# Google Places API key (for /api/leads endpoints)
# Get one at: https://console.cloud.google.com/apis/library/places-backend.googleapis.com
# Enable: "Places API" in Google Cloud Console
GOOGLE_PLACES_API_KEY=
