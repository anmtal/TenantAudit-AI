{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node"
    },
    {
      "src": "index.html",
      "use": "@vercel/static"
    },
    {
      "src": "styles.css",
      "use": "@vercel/static"
    },
    {
      "src": "app.js",
      "use": "@vercel/static"
    },
    {
      "src": "assets/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "headers": { "Cache-Control": "no-store, no-cache, must-revalidate, proxy-revalidate" },
      "dest": "server.js"
    },
    {
      "src": "/(.*)",
      "headers": { "Cache-Control": "no-store, no-cache, must-revalidate, proxy-revalidate" },
      "dest": "/$1"
    }
  ]
}
